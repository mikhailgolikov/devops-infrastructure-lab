[Unit]
Description={{redis_description}}
After=network.target

[Service]
ExecStart=/usr/bin/redis-server {{cluster_config_file}}/%i/redis_%i.conf --supervised systemd
ExecStop=/bin/redis-cli -h {{redis_host}} -p %i shutdown
Type=notify
User={{redis_user}}
Group={{redis_user}}
RuntimeDirectory=redis-%i
RuntimeDirectoryMode=0755
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target

